<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="4dp"
    android:padding="16dp"
    android:gravity="center_vertical"
    android:background="@drawable/bg_item_box"
    android:elevation="2dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvItemUserId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User_ID"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvItemReason"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="추천친구"
                android:textColor="#FF8A00"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_text_box"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvItemLevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Lv.1"
            android:textColor="#777777"
            android:textSize="13sp" />

    </LinearLayout>

    <ImageButton
        android:id="@+id/btnItemAddFriend"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="8dp"
        android:src="@drawable/ic_add_friend"
        android:background="@drawable/bg_circle_button"
        android:backgroundTint="#F5EBE0"
        android:padding="8dp"
        android:scaleType="fitCenter"
        app:tint="#333333"
        android:contentDescription="친구 추가 버튼"/>

</LinearLayout>
