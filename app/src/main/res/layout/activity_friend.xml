<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E8F4F8"
    android:padding="20dp">

    <!-- 🏷상단: 내 아이디 표시 & 추천 친구 영역 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/tv_my_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="내 아이디: 불러오는 중..."
            android:textColor="#333333"
            android:textSize="15sp"
            android:textStyle="bold"

            android:background="@drawable/bg_text_box"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:elevation="1dp"/>

        <Button
            android:id="@+id/btn_recommended_friends"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:backgroundTint="#FFFFFF"
            android:text="추천 친구"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="20dp"
            app:strokeColor="#000000"
            app:strokeWidth="2dp" />

    </RelativeLayout>

    <!-- 메인: 친구 추가 컨테이너 카드 (화면 이미지 디자인 반영) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_item_box"
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="친구 추가"
            android:textColor="#000000"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp"
            android:text="추가할 친구의 유저 아이디를 입력하세요"
            android:textColor="#666666"
            android:textSize="14sp" />

        <!--자바 코드의 editSearchEmail = findViewById(R.id.edit_search_email); 과 매칭 -->
        <EditText
            android:id="@+id/edit_search_email"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_text_box"
            android:hint="유저 아이디 입력"
            android:inputType="text"
            android:paddingHorizontal="16dp"
            android:textColor="#000000"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="end"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:backgroundTint="#00000000"
                android:text="취소"
                android:textColor="#666666"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!--자바 코드의 btnSearchFriend = findViewById(R.id.btn_search_friend); 와 매칭 -->
            <Button
                android:id="@+id/btn_search_friend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#00000000"
                android:text="추가하기"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                app:strokeColor="#000000"
                app:strokeWidth="2dp"
                app:cornerRadius="20dp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="내 친구 목록 (요청 상태 포함)"
        android:textColor="#333333"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <!-- 👥 자바 코드의 recyclerView = findViewById(R.id.recycler_friends); 와 매칭 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_friends"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="vertical" />

</LinearLayout>