<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/friend_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF8F0"
    android:padding="20dp">

    <TextView
        android:id="@+id/tv_friend_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="친구"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#2F2F2F"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:id="@+id/layout_my_user_id"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tv_my_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="내 아이디:"
            android:textSize="15sp"
            android:textColor="#333333" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_search_friend"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">
        <!--자바 코드의 editSearchEmail = findViewById(R.id.edit_search_email); 과 매칭 -->
        <EditText
            android:id="@+id/edit_search_email"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="아이디 또는 이름 입력"
            android:singleLine="true"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="#FFFFFF"
            android:textColor="#333333"
            android:textColorHint="#999999" />

        <Button
            android:id="@+id/btn_search_friend"
            android:layout_width="90dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:text="신청"
            android:textSize="14sp" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_recommended_friends"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="추천 친구 찾기"
        android:textSize="15sp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#FFFFFF"
        android:textColor="#333333" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_friends"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

</LinearLayout>