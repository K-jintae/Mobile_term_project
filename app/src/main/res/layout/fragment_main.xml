<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E6F0F2">

    <ImageView
        android:id="@+id/logoImage"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="58dp"
        android:src="@drawable/logo"
        android:contentDescription="로고"
        android:adjustViewBounds="true"
        android:elevation="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <FrameLayout
        android:id="@+id/sceneCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="150dp"
        android:layout_marginBottom="20dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_scene_card_border"
        android:elevation="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/msg_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="1:1">

        <FrameLayout
            android:id="@+id/sceneCardInner"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="2.5dp"
            android:background="@drawable/bg_scene_card_inner"
            android:clipToOutline="true"
            android:outlineProvider="background">

            <ImageView
                android:id="@+id/bgInterior"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/background_hill" />

            <FrameLayout
                android:id="@+id/characterContainer"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_gravity="center|bottom"
                android:layout_marginBottom="26dp">

                <ImageView
                    android:id="@+id/characterImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:src="@drawable/character_base" />

                <ImageView
                    android:id="@+id/clothes_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter" />

                <ImageView
                    android:id="@+id/face_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter" />

                <ImageView
                    android:id="@+id/hat_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter" />
            </FrameLayout>

        </FrameLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/msg_container"
        android:layout_width="352dp"
        android:layout_height="120dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="100dp"
        android:background="@drawable/bg_message_box"
        android:elevation="6dp"
        android:padding="18dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.454"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tv_message"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="안녕! 잘 지냈어?!"
            android:textColor="#000000"
            android:textSize="20sp" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/quiz_container"
        android:layout_width="204dp"
        android:layout_height="54dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="36dp"
        android:background="@drawable/bg_message_box"
        android:elevation="6dp"
        android:padding="18dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/quiz_message"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="문제 이어풀기"
            android:textColor="#000000"
            android:textSize="15sp" />
    </FrameLayout>

    <ImageButton
        android:id="@+id/btnOpenFriend"
        android:layout_width="54dp"
        android:layout_height="48dp"
        android:layout_marginEnd="12dp"
        android:src="@drawable/ic_add_friend"

        android:background="@drawable/bg_circle_button"

        android:backgroundTint="#F5EBE0"

        android:scaleType="fitCenter"
        android:padding="10dp"
        app:tint="@null"

        android:elevation="6dp"
        android:contentDescription="친구 관리 버튼"
        app:layout_constraintEnd_toStartOf="@id/btnSettings"
        app:layout_constraintTop_toTopOf="@id/btnSettings"
        app:layout_constraintBottom_toBottomOf="@id/btnSettings" />

    <ImageButton
        android:id="@+id/btnSettings"
        android:layout_width="54dp"
        android:layout_height="48dp"
        android:layout_marginTop="80dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_circle_button"
        android:contentDescription="설정"
        android:padding="8dp"
        android:scaleType="fitCenter"
        android:src="@drawable/button_setting"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="6dp" />

    <View
        android:id="@+id/dimView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#66000000"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="6dp"/>


    <LinearLayout
        android:id="@+id/helpPopup"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:maxHeight="500dp"
        android:background="@drawable/bg_popup_panel"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"
            android:text="도움말"
            android:textColor="#2B2B2B"
            android:textSize="24sp"
            android:textStyle="bold"
            android:elevation="6dp"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp">

            <TextView
                android:id="@+id/tvHelpContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="도움말 내용 작성하기"
                android:textColor="#2B2B2B"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.5"
                android:elevation="6dp"/>
        </ScrollView>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCloseHelpPopup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="닫기"
            android:textColor="#2B2B2B"
            android:background="@drawable/bg_btn_inset"
            android:backgroundTint="@null"
            android:minHeight="0dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:elevation="6dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/soundSettingsPopup"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_popup_panel"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"
            android:text="소리 설정"
            android:textColor="#2B2B2B"
            android:textSize="24sp"
            android:textStyle="bold"
            android:elevation="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="15dp">

            <FrameLayout
                android:id="@+id/btnSoundOn"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:background="@drawable/bg_btn_inset"
                android:padding="12dp"
                android:layout_marginEnd="10dp">

                <ImageView
                    android:id="@+id/iconSpeaker"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:src="@drawable/speaker_icon"
                    android:contentDescription="음성 ON" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/btnSoundMute"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:background="@drawable/bg_btn_inset"
                android:padding="12dp"
                android:layout_marginStart="10dp">

                <ImageView
                    android:id="@+id/iconMute"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:src="@drawable/mute_icon"
                    android:contentDescription="음성 OFF" />
            </FrameLayout>
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCloseSoundPopup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="6dp"
            android:text="닫기"
            android:textColor="#2B2B2B"
            android:background="@drawable/bg_btn_inset"
            android:backgroundTint="@null"
            android:minHeight="0dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:elevation="6dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/settingsPopup"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_popup_panel"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"
            android:text="설정"
            android:textColor="#2B2B2B"
            android:textSize="24sp"
            android:textStyle="bold"
            android:elevation="6dp"/>

        <!--닉네임 수정 버튼-->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnEditNickname"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="닉네임 수정"
            android:textColor="#2B2B2B"
            android:background="@drawable/bg_btn_inset_accent"
            android:minHeight="0dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:elevation="6dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="소리 설정"
            android:textColor="#2B2B2B"
            android:background="@drawable/bg_btn_inset"
            android:backgroundTint="@null"
            android:minHeight="0dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:elevation="6dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnHelp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="도움말"
            android:textColor="#2B2B2B"
            android:background="@drawable/bg_btn_inset"
            android:backgroundTint="@null"
            android:minHeight="0dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:elevation="6dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/logoutBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="로그아웃"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn_inset_red"
            android:backgroundTint="@null"
            android:minHeight="0dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:elevation="6dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnClosePopup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="6dp"
            android:text="닫기"
            android:textColor="#2B2B2B"
            android:background="@drawable/bg_btn_inset"
            android:backgroundTint="@null"
            android:minHeight="0dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:elevation="6dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nicknamePopup"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_popup_panel"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"
            android:text="닉네임 수정"
            android:textColor="#2B2B2B"
            android:textSize="24sp"
            android:textStyle="bold"
            android:elevation="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp"
            android:background="@drawable/bg_edittext_outline"
            android:orientation="horizontal"
            android:gravity="center_vertical" android:elevation="4dp">

            <EditText
                android:id="@+id/etNickname"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:hint="새 닉네임 (최대 8자)"
                android:inputType="text"
                android:maxLength="8"
                android:singleLine="true"
                android:scrollHorizontally="true" android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:textColor="#2B2B2B"
                android:textSize="16sp"/>

            <ImageButton
                android:id="@+id/btnClearNickname"
                android:layout_width="40dp" android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"
                android:padding="10dp" android:src="@drawable/delete_x" android:contentDescription="초기화"/>
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSaveNickname"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="저장"
            android:textColor="#2B2B2B"
            android:background="@drawable/bg_btn_inset"
            android:backgroundTint="@null"
            android:minHeight="0dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:elevation="6dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCloseNicknamePopup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="6dp"
            android:text="닫기"
            android:textColor="#2B2B2B"
            android:background="@drawable/bg_btn_inset"
            android:backgroundTint="@null"
            android:minHeight="0dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:elevation="6dp"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
