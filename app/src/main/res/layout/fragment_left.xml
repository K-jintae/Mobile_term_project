<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E6F0F2"
    android:paddingTop="36dp">

    <!-- 상단 소개 카드 -->
    <FrameLayout
        android:id="@+id/quizTopCard"
        android:layout_width="0dp"
        android:layout_height="170dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="36dp"
        android:background="@drawable/bg_scene_card_border"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="2.5dp"
            android:background="@drawable/bg_scene_card_inner"
            android:clipToOutline="true"
            android:outlineProvider="background">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/quizbackground"
                android:background="#DDEFEF"
                android:scaleType="centerCrop" />

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvQuizHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="퀴즈 풀기"
                    android:textColor="#000000"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvQuizSubHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="퀴즈를 풀고 골드를 획득해보자!"
                    android:textColor="#000000"
                    android:textSize="14sp" />
            </LinearLayout>
        </FrameLayout>
    </FrameLayout>

    <!-- 카드 리스트 -->
    <ScrollView
        android:id="@+id/quizScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="16dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/quizTopCard"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 1: C언어 -->
            <LinearLayout
                android:id="@+id/cardQuiz1"
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_message_box"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_button"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="#2B2B2B"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvQuizTitle1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="C언어"
                        android:textColor="#222222"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvQuizDesc1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="C 언어에 대한 기본 이해"
                        android:textColor="#444444"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 2: DB -->
            <LinearLayout
                android:id="@+id/cardQuiz2"
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_message_box"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_button"
                    android:gravity="center"
                    android:text="2"
                    android:textColor="#2B2B2B"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvQuizTitle2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DB"
                        android:textColor="#222222"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvQuizDesc2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="데이터베이스에 대한 기본 이해"
                        android:textColor="#444444"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 3: 알고리즘 -->
            <LinearLayout
                android:id="@+id/cardQuiz3"
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_message_box"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_button"
                    android:gravity="center"
                    android:text="3"
                    android:textColor="#2B2B2B"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvQuizTitle3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="알고리즘"
                        android:textColor="#222222"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvQuizDesc3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="알고리즘에 대한 기본 이해"
                        android:textColor="#444444"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 4: 객체지향프로그래밍 -->
            <LinearLayout
                android:id="@+id/cardQuiz4"
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_message_box"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_button"
                    android:gravity="center"
                    android:text="4"
                    android:textColor="#2B2B2B"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvQuizTitle4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="객체지향프로그래밍"
                        android:textColor="#222222"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvQuizDesc4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Java와 OOP의 핵심 개념 이해"
                        android:textColor="#444444"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 5: 인공지능개론 -->
            <LinearLayout
                android:id="@+id/cardQuiz5"
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_message_box"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_button"
                    android:gravity="center"
                    android:text="5"
                    android:textColor="#2B2B2B"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvQuizTitle5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="인공지능개론"
                        android:textColor="#222222"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvQuizDesc5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="머신러닝과 딥러닝 기초 이해"
                        android:textColor="#444444"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 6: 데이터과학 -->
            <LinearLayout
                android:id="@+id/cardQuiz6"
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_message_box"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_button"
                    android:gravity="center"
                    android:text="6"
                    android:textColor="#2B2B2B"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvQuizTitle6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="데이터과학"
                        android:textColor="#222222"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvQuizDesc6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="데이터 분석과 통계의 기초"
                        android:textColor="#444444"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 7: 컴퓨터네트워크 -->
            <LinearLayout
                android:id="@+id/cardQuiz7"
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_message_box"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_button"
                    android:gravity="center"
                    android:text="7"
                    android:textColor="#2B2B2B"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvQuizTitle7"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="컴퓨터네트워크"
                        android:textColor="#222222"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvQuizDesc7"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="네트워크 프로토콜과 통신 이해"
                        android:textColor="#444444"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 8: 자료구조 -->
            <LinearLayout
                android:id="@+id/cardQuiz8"
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_message_box"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_button"
                    android:gravity="center"
                    android:text="8"
                    android:textColor="#2B2B2B"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvQuizTitle8"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="자료구조"
                        android:textColor="#222222"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvQuizDesc8"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="스택, 큐, 트리 등 자료구조 이해"
                        android:textColor="#444444"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 9: 운영체제 -->
            <LinearLayout
                android:id="@+id/cardQuiz9"
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_message_box"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_button"
                    android:gravity="center"
                    android:text="9"
                    android:textColor="#2B2B2B"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvQuizTitle9"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="운영체제"
                        android:textColor="#222222"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvQuizDesc9"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="프로세스와 메모리 관리 기초"
                        android:textColor="#444444"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
