<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 선택됨 -->
    <item android:state_checked="true">
        <layer-list>
            <item
                android:width="24dp"
                android:height="24dp"
                android:gravity="center">
                <shape android:shape="oval">
                    <solid android:color="#FFFFFF"/>
                    <stroke
                        android:width="2.5dp"
                        android:color="#F28C38"/>
                </shape>
            </item>

            <item
                android:width="12dp"
                android:height="12dp"
                android:gravity="center">
                <shape android:shape="oval">
                    <solid android:color="#F28C38"/>
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- 선택 안 됨 -->
    <item>
        <layer-list>
            <item
                android:width="24dp"
                android:height="24dp"
                android:gravity="center">
                <shape android:shape="oval">
                    <solid android:color="#FFFFFF"/>
                    <stroke
                        android:width="2.5dp"
                        android:color="#555555"/>
                </shape>
            </item>
        </layer-list>
    </item>

</selector>